# MongoDB
MONGODB_URI=your_mongodb_connection_string
MONGODB_DB_NAME=sim-finder-admin
# Optional source DB name for one-time migration into MONGODB_DB_NAME
MONGODB_SOURCE_DB_NAME=sim-finder
# Newsletter subscribers are read from frontend DB by admin panel
NEWSLETTER_DB_NAME=sim-finder
NEWSLETTER_COLLECTION=newsletter_subscribers

# JWT
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Admin Credentials (used by seed script)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# API Defaults
API1_URL=https://example.com/api1
API2_URL=https://example.com/api2
API_TIMEOUT=10000

# Cache TTL in seconds
CACHE_TTL=300

# Comma-separated list of web origins allowed to call public API routes
# Example: http://localhost:5050,https://your-frontend.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:5050
